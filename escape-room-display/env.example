# Copy to .env (then `set -a; . .env; set +a`) or export in your shell.
# All are optional.

# Where the LED `spell.py` lives on the slave (default shown):
# SPELLS_DIR=/home/cde/copperdragons/led_screen/spells

# Which Python to use (must have rgbmatrix available):
# VENV_PYTHON=/home/cde/copperdragons/.venv/bin/python

# Which spell names are allowed (comma separated):
# VALID_SPELLS=fireball,void

# 1 on the Pi (needs sudo for GPIO), 0 for laptop / mock:
# USE_SUDO=1

# If set, clients MUST send this in header: X-API-Key: <value>
# DISPLAY_API_KEY=change-me-to-a-long-random-string
